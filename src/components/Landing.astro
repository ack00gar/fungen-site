---
import AiSection from './AiSection.astro';
import BrandMark from './BrandMark.astro';
import LangSwitcher from './LangSwitcher.astro';
import PricingSection from './PricingSection.astro';
import Wordmark from './Wordmark.astro';
import { LINKS, DEVICES } from '../consts';
import { t, type Locale } from '../i18n';
import { SHOWCASE } from '../i18n/showcase';
import { discordMembers } from '../discord';

interface Props { lang: Locale }
const { lang } = Astro.props;
const s = t(lang);
const sc = SHOWCASE[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const shot = (n: string) => `${base}/shots/${n}.webp`;

// Live-ish Discord member count (build time) for the hero social-proof line.
const discordCount = await discordMembers();
const communityText = (sc.community ?? 'Join {n}+ on Discord').replace('{n}', discordCount.toLocaleString());

// The {braces} in hero.head used to mark a teal-highlighted word; the
// highlight was dropped (too much accent next to the wordmark) so all
// segments now render plain - braces are just stripped.
const headParts = s.hero.head.split(/\{([^}]*)\}/);

// Alternating feature deep-dives. Chapters/bookmarks + streamer rows removed
// 2026-07-02, and Doctor/transforms/palette moved to the dedicated /studio/
// page 2026-07-08: power-user depth overwhelmed first-time visitors (the
// dict entries stay - the Studio page renders from them).
const DIVES = [] as { d: typeof sc.doctor; img: string; w: number; h: number; vid?: string }[];
---

<!-- ░░ NAV ░░ -->
<header class="nav">
  <div class="wrap nav-inner">
    <a class="logo" href="#top">
      <img src={`${base}/icon-256.png`} alt="FunGen logo" width="32" height="32" />
      <span><Wordmark /></span>
    </a>
    <nav class="nav-links">
      <a href="#ai">{s.nav.ai}</a>
      <a href="#features">{s.nav.features}</a>
      <a href="#devices">{s.nav.devices}</a>
      <a href="#pricing">{s.nav.pricing}</a>
      <a href="#faq">{s.nav.faq}</a>
    </nav>
    <div class="nav-right">
      <LangSwitcher current={lang} />
      <a class="nav-cta" href={LINKS.releases} target="_blank" rel="noopener" data-umami-event="download-nav" data-os-cta data-os-tpl={s.hero.osCta}>{s.nav.download}</a>
    </div>
  </div>
</header>

<main id="top">
  <!-- ░░ HERO ░░ -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="lockup">
        <BrandMark size={190} />
        <div class="wordmark"><Wordmark /></div>
      </div>
      <h1 class="hero-head">
        {headParts.join('')}
      </h1>
      <figure class="hero-video">
        <video width="2400" height="328" poster={`${base}/shots/fungenerate-poster.webp`} {...({ fetchpriority: 'high' } as Record<string, string>)} autoplay muted loop playsinline preload="metadata" aria-label={sc.gen.alt}>
          <source src={`${base}/shots/fungenerate.webm`} type="video/webm" />
          <source src={`${base}/shots/fungenerate.mp4`} type="video/mp4" />
        </video>
      </figure>
      <div class="hero-cta">
        <a class="btn btn-primary" href={LINKS.releases} target="_blank" rel="noopener" data-umami-event="download-hero" data-os-cta data-os-tpl={s.hero.osCta}>{s.hero.ctaDownload}</a>
      </div>
      <a class="hero-social" href={LINKS.discord} target="_blank" rel="noopener" data-umami-event="discord-hero">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.6 12.6 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.009c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.891.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.331c-1.182 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>{communityText}
      </a>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  <!-- ░░ AI MODELS ░░ -->
  <AiSection lang={lang} />

  <!-- ░░ EDITOR HERO ░░ -->
  <section id="features" class="show-hero">
    <div class="wrap" data-reveal>
      <div class="section-head section-head--center">
        <p class="eyebrow">{sc.editor.eyebrow}</p>
        <h2>{sc.editor.title}</h2>
        <p>{sc.editor.body}</p>
      </div>
      <figure class="hero-shot">
        <img src={shot('editor-1')} width="2800" height="1488" loading="eager" decoding="async" fetchpriority="high" alt={sc.editor.alt} />
      </figure>
    </div>
  </section>

  <!-- ░░ FEATURE DEEP-DIVES ░░ -->
  {DIVES.map((row, i) => (
    <section class="show">
      <div class={`wrap show-row${i % 2 ? ' show-row--rev' : ''}`} data-reveal>
        <div class="show-media">
          {row.vid ? (
            <video class="show-frame" width={row.w} height={row.h} poster={`${base}/shots/${row.vid}-poster.webp`} autoplay muted loop playsinline preload="metadata" aria-label={row.d.alt}>
              <source src={`${base}/shots/${row.vid}.mp4`} type="video/mp4" />
            </video>
          ) : (
            <img class="show-frame" src={shot(row.img)} width={row.w} height={row.h} loading="lazy" decoding="async" alt={row.d.alt} />
          )}
        </div>
        <div class="show-text">
          <p class="eyebrow">{row.d.eyebrow}</p>
          <h2>{row.d.title}</h2>
          <p>{row.d.body}</p>
        </div>
      </div>
    </section>
  ))}

  <!-- ░░ DEVICES ░░ -->
  <section id="devices" class="devices">
    <div class="wrap devices-inner" data-reveal>
      <div>
        <div class="section-head" style="margin-bottom:24px">
          <p class="eyebrow">{s.devices.eyebrow}</p>
          <h2>{s.devices.title}</h2>
          <p>{s.devices.body}</p>
        </div>
        <ul class="device-list">
          {DEVICES.map((d) => <li>{d}</li>)}
        </ul>
        <a class="device-more" href={`${base}/supported-devices/`}>How FunGen drives each device →</a>
      </div>
      <figure class="devices-shot">
        <img class="show-frame" src={shot('devices')} width="894" height="1316" loading="lazy" decoding="async" alt={sc.devicesAlt} />
      </figure>
    </div>
  </section>

  <!-- ░░ PRICING ░░ -->
  <PricingSection lang={lang} />

  <!-- ░░ FAQ ░░ -->
  <section id="faq" class="faq">
    <div class="wrap" data-reveal>
      <div class="section-head">
        <p class="eyebrow">{s.faq.eyebrow}</p>
        <h2>{s.faq.title}</h2>
      </div>
      <div class="faq-list">
        {s.faq.items.map((item) => (
          <details>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ FINAL CTA ░░ -->
  <section class="final-cta">
    <div class="wrap final-inner" data-reveal>
      <h2>{s.finalCta.title}</h2>
      <p>{s.finalCta.body}</p>
      <a class="btn btn-primary" href={LINKS.releases} target="_blank" rel="noopener" data-umami-event="download-final">{s.finalCta.cta}</a>
    </div>
  </section>
</main>

<!-- Sticky mobile-only download bar: appears once the hero scrolls off-screen. -->
<a class="btn btn-primary mobile-dl" href={LINKS.releases} target="_blank" rel="noopener" data-umami-event="download-sticky">{s.finalCta.cta}</a>

<!-- ░░ FOOTER ░░ -->
<footer class="footer">
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <img src={`${base}/icon-256.png`} alt="FunGen logo" width="28" height="28" />
      <div>
        <strong><Wordmark /></strong>
      </div>
    </div>
    <nav class="footer-links">
      <a href={LINKS.releases} target="_blank" rel="noopener" data-umami-event="download-footer">{s.footer.download}</a>
      <a href={LINKS.patreon} target="_blank" rel="noopener" data-umami-event="patreon">{s.footer.patreon}</a>
      <a href={LINKS.discord} target="_blank" rel="noopener" data-umami-event="discord">{s.footer.discord}</a>
      <a href={LINKS.contact}>{s.footer.contact}</a>
    </nav>
    <nav class="footer-links footer-guides" aria-label="Guides">
      <a href={`${base}/what-is-a-funscript/`}>What is a funscript?</a>
      <a href={`${base}/generate-funscripts-from-video/`}>Generate from video</a>
      <a href={`${base}/funscript-editor/`}>Funscript editor</a>
      <a href={`${base}/studio/`}>The Studio</a>
      <a href={`${base}/vr-funscripts/`}>VR funscripts</a>
      <a href={`${base}/stash-xbvr-funscripts/`}>Stash &amp; XBVR</a>
      <a href={`${base}/supported-devices/`}>Supported devices</a>
      <a href={`${base}/funscripts-for-the-handy/`}>The Handy</a>
      <a href={`${base}/funscripts-for-osr2-sr6/`}>OSR2 / SR6</a>
      <a href={`${base}/changelog/`}>Changelog</a>
    </nav>
    <p class="footer-fine">{s.footer.fine}</p>
  </div>
</footer>

<script>
  // ── OS-aware download CTA (progressive enhancement) ───────────────────────
  // The generic label is server-rendered; if we can confidently detect a desktop
  // OS we relabel every [data-os-cta] to "Download for <OS>" and reveal the
  // secondary "Also for …" line. Mobile/unknown falls back to the generic label.
  (function () {
    var ua = navigator.userAgent || '';
    var uaData = (navigator as any).userAgentData;
    var plat = (uaData && uaData.platform) || navigator.platform || '';
    var hay = plat + ' ' + ua;
    var os = null;
    if (/Android/i.test(ua)) os = null;
    else if (/Mac/i.test(hay) && !/iPhone|iPad|iPod/i.test(hay) && !(navigator.maxTouchPoints > 1)) os = 'macOS';
    else if (/Win/i.test(hay)) os = 'Windows';
    else if (/Linux|X11|CrOS/i.test(hay)) os = 'Linux';
    if (os) {
      document.querySelectorAll('[data-os-cta]').forEach(function (el) {
        var tpl = el.getAttribute('data-os-tpl');
        if (tpl) el.textContent = tpl.replace('{os}', os);
      });
      var others = ['Windows', 'macOS', 'Linux'].filter(function (o) { return o !== os; });
      document.querySelectorAll('[data-os-also]').forEach(function (el) {
        var tpl = el.getAttribute('data-os-tpl');
        if (tpl) { el.textContent = tpl.replace('{platforms}', others.join(' · ')); el.removeAttribute('hidden'); }
      });
    }
  })();

  // ── Sticky mobile download bar ────────────────────────────────────────────
  // Reveal the fixed bar once the hero is fully scrolled past (CSS handles the
  // mobile-only display + the prefers-reduced-motion transition).
  (function () {
    var hero = document.querySelector('.hero');
    var bar = document.querySelector('.mobile-dl');
    if (!hero || !bar || !('IntersectionObserver' in window)) return;
    new IntersectionObserver(function (entries) {
      bar.classList.toggle('is-visible', !entries[0].isIntersecting);
    }, { threshold: 0 }).observe(hero);
  })();
</script>

<style>
  /* NAV */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: rgba(11, 15, 20, 0.72);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner { display: flex; align-items: center; gap: 24px; height: 64px; }
  .logo { display: flex; align-items: center; gap: 10px; font-weight: 750; font-size: 1.1rem; }
  .logo img { border-radius: 8px; }
  .nav-links { display: flex; gap: 22px; margin-left: auto; color: var(--muted); font-size: 0.94rem; }
  .nav-links a:hover { color: var(--text); }
  .nav-right { display: flex; align-items: center; gap: 10px; }
  .nav-links + .nav-right { margin-left: 0; }
  .nav-links { margin-left: auto; }
  .nav-cta { color: var(--muted); font-size: 0.94rem; }
  .nav-cta:hover { color: var(--text); }
  @media (max-width: 820px) {
    .nav-links { display: none; }
    .nav-right { margin-left: auto; }
  }

  /* HERO */
  .hero { position: relative; padding: 44px 0 64px; overflow: hidden; }
  .hero-inner {
    position: relative; z-index: 2; max-width: 940px; margin: 0 auto; text-align: center;
    display: flex; flex-direction: column; align-items: center;
  }
  .lockup { display: flex; flex-direction: column; align-items: center; margin-bottom: 22px; }
  .lockup :global(.bmark) { display: block; }
  .wordmark {
    font-size: clamp(2.2rem, 5vw, 3rem); font-weight: 800; letter-spacing: -0.03em;
    margin-top: 8px; opacity: 0; animation: rise 0.7s ease-out 0.3s forwards;
  }
  @keyframes rise {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-head {
    font-size: clamp(2rem, 4.8vw, 3rem); font-weight: 800; max-width: 680px;
    opacity: 0; animation: rise 0.7s ease-out 0.55s forwards;
  }
  .hero-card {
    max-width: 680px; margin: 30px auto 0; padding: 26px 30px 22px;
    background: linear-gradient(180deg, rgba(20,27,36,0.85), rgba(13,18,25,0.85));
    border: 1px solid var(--line); border-radius: 18px; backdrop-filter: blur(6px);
  }
  .hero-card .hero-sub { margin: 0 auto; color: #d4dce5; line-height: 1.65; font-size: clamp(1.05rem, 2vw, 1.2rem); max-width: 480px; }
  .hero-sub {
    font-size: clamp(1.02rem, 2vw, 1.18rem); color: var(--muted); max-width: 600px; margin: 22px auto 30px;
    opacity: 0; animation: rise 0.7s ease-out 0.7s forwards;
  }
  .hero-cta {
    display: flex; flex-wrap: wrap; gap: 14px; justify-content: center;
    margin-top: 40px;
    opacity: 0; animation: rise 0.7s ease-out 0.85s forwards;
  }
  .hero-meta {
    margin-top: 20px; color: var(--muted); font-size: 0.94rem;
    opacity: 0; animation: rise 0.7s ease-out 1s forwards;
  }
  .hero-social {
    display: inline-flex; align-items: center; gap: 8px; margin-top: 14px;
    color: var(--muted); font-size: 0.9rem; font-weight: 550;
    opacity: 0; animation: rise 0.7s ease-out 1.15s forwards;
  }
  .hero-social:hover { color: var(--text); }
  .hero-social svg { flex: none; opacity: 0.9; }
  .hero-social:hover svg { color: #5865F2; opacity: 1; }
  .hero-also {
    margin: 12px 0 0; color: var(--muted); font-size: 0.86rem;
    opacity: 0; animation: rise 0.7s ease-out 0.95s forwards;
  }
  .hero-trust {
    list-style: none; display: flex; flex-wrap: wrap; justify-content: center;
    gap: 6px 0; margin: 14px 0 0; padding: 0;
    text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.7rem; font-weight: 700;
    color: var(--muted);
    opacity: 0; animation: rise 0.7s ease-out 1.05s forwards;
  }
  .hero-trust li:not(:first-child) { margin-left: 14px; }
  .hero-trust li:not(:first-child)::before { content: '·'; margin-right: 14px; color: var(--line); }
  @media (prefers-reduced-motion: reduce) {
    .wordmark, .hero-head, .hero-sub, .hero-cta, .hero-meta, .hero-social, .hero-video,
    .hero-also, .hero-trust {
      animation: none; opacity: 1;
    }
  }
  .hero-glow {
    position: absolute;
    top: -260px; left: 50%; transform: translateX(-50%);
    width: 860px; height: 760px;
    background: radial-gradient(circle at 50% 42%, rgba(34, 211, 238, 0.13), transparent 60%);
    filter: blur(24px);
    z-index: 1;
    pointer-events: none;
  }

  /* SCREENSHOT */
  .shot-frame {
    margin: 0; border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: 0 40px 120px -50px rgba(34, 211, 238, 0.45), 0 20px 60px -40px rgba(0, 0, 0, 0.8);
    background: var(--bg-soft);
  }
  .shot-frame img { display: block; width: 100%; height: auto; }


  /* FEATURE SHOWCASE */
  .show-hero, .show, .gen { min-height: auto; padding: 84px 0; scroll-snap-align: none; }
  .section-head--center { margin-left: auto; margin-right: auto; text-align: center; }
  .hero-shot { margin: 40px auto 0; max-width: 1040px; }
  .hero-shot img { width: 100%; height: auto; }
  .hero-shot img, .show-frame, .hero-video video, .devices-shot img {
    display: block; border-radius: var(--radius);
    box-shadow: 0 40px 120px -52px rgba(34, 211, 238, 0.42), 0 24px 64px -44px rgba(0, 0, 0, 0.85);
  }
  /* keep the card frame on videos only; images sit frameless */
  .hero-video video, video.show-frame { border: 1px solid var(--line); background: var(--bg-soft); }
  .show-row { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
  .show-row--rev .show-media { order: 2; }
  .show-media { display: flex; justify-content: center; }
  .show-frame { max-width: 100%; max-height: 540px; width: auto; height: auto; }
  .show-text h2 { font-size: clamp(1.55rem, 3vw, 2.2rem); margin: 12px 0 14px; }
  .show-text > p { color: var(--muted); font-size: 1.05rem; margin: 0; }
  .chips { list-style: none; display: flex; flex-wrap: wrap; gap: 10px; margin: 22px 0 0; padding: 0; }
  .chips li {
    font-size: 0.8rem; font-weight: 600; color: var(--teal);
    border: 1px solid rgba(34, 211, 238, 0.3); background: rgba(34, 211, 238, 0.08);
    border-radius: 999px; padding: 6px 12px;
  }
  .chips--center { justify-content: center; margin-top: 30px; }
  .hero-video {
    width: 100%; max-width: 880px; margin: 34px auto 12px; padding: 0;
    opacity: 0; animation: rise 0.7s ease-out 0.62s forwards;
  }
  .hero-video video { width: 100%; height: auto; }
  .hero-video-cap {
    text-transform: uppercase; letter-spacing: 0.16em; font-size: 0.68rem; font-weight: 700;
    color: var(--teal); margin-bottom: 12px;
  }
  .devices-shot { margin: 0; }
  .devices-shot img { width: 100%; height: auto; max-height: 660px; object-fit: contain; }

  /* Scroll-driven parallax drift on the framed media; the [data-reveal] fade
     handles entrance, and this is a no-op where unsupported or reduced-motion. */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .show-frame, .hero-shot img, .gen-video video {
        animation: media-parallax linear both;
        animation-timeline: view();
        animation-range: entry 0% exit 100%;
      }
      @keyframes media-parallax {
        from { transform: translateY(26px); }
        to { transform: translateY(-26px); }
      }
    }
  }

  @media (max-width: 900px) {
    .show-row { grid-template-columns: 1fr; gap: 28px; }
    .show-row--rev .show-media { order: 0; }
  }

  /* DEVICES */
  .devices { background: var(--bg-soft); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .devices-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .device-list { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .device-list li {
    background: var(--card); border: 1px solid var(--line); border-radius: 12px;
    padding: 14px 16px; font-size: 0.94rem; font-weight: 550;
  }
  .device-list li::before { content: '⇄'; color: var(--coral); margin-right: 10px; }
  .device-more { display: inline-block; margin-top: 18px; color: var(--teal); font-weight: 600; font-size: 0.95rem; }
  .device-more:hover { text-decoration: underline; }
  @media (max-width: 860px) { .devices-inner { grid-template-columns: 1fr; gap: 32px; } }


  /* FAQ */
  .faq { background: var(--bg-soft); border-top: 1px solid var(--line); }
  .faq-list { display: grid; gap: 12px; }
  details {
    background: var(--card); border: 1px solid var(--line); border-radius: 12px; padding: 4px 20px;
  }
  summary { cursor: pointer; font-weight: 650; padding: 16px 0; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  summary::after { content: '+'; color: var(--teal); font-size: 1.3rem; }
  details[open] summary::after { content: '–'; }
  details p { color: var(--muted); margin: 0 0 18px; font-size: 0.96rem; }

  /* FINAL CTA */
  .final-cta { text-align: center; scroll-snap-align: none; }
  .final-inner h2 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: 12px; }
  .final-inner p { color: var(--muted); margin-bottom: 28px; }

  /* FOOTER */
  .footer { border-top: 1px solid var(--line); padding: 48px 0; }
  .footer-inner { display: flex; flex-wrap: wrap; gap: 20px; align-items: center; justify-content: space-between; }
  .footer-brand { display: flex; align-items: center; gap: 12px; }
  .footer-brand img { border-radius: 7px; }
  .footer-brand strong { display: block; }
  .footer-brand span { color: var(--muted); font-size: 0.85rem; }
  .footer-links { display: flex; flex-wrap: wrap; gap: 20px; color: var(--muted); font-size: 0.92rem; }
  .footer-guides { font-size: 0.85rem; opacity: 0.92; }
  .footer-guides a:hover { color: var(--teal); }
  .footer-links a:hover { color: var(--text); }
