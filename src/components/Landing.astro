---
import BrandMark from './BrandMark.astro';
import LangSwitcher from './LangSwitcher.astro';
import { LINKS, AI_TAGS, DEVICES, PLAN_META, PROMO, PROMO_ACTIVE, PROMO_ENDS, CRYPTO } from '../consts';
import { t, type Locale } from '../i18n';
import { SHOWCASE } from '../i18n/showcase';
import { discordMembers } from '../discord';

interface Props { lang: Locale }
const { lang } = Astro.props;
const s = t(lang);
const sc = SHOWCASE[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const shot = (n: string) => `${base}/shots/${n}.webp`;

// Live-ish Discord member count (build time) for the hero social-proof line.
const discordCount = await discordMembers();
const communityText = (sc.community ?? 'Join {n}+ on Discord').replace('{n}', discordCount.toLocaleString());

// Split "Turn video into {funscripts}." into segments; odd indices are the
// gradient-highlighted brand word(s).
const headParts = s.hero.head.split(/\{([^}]*)\}/);

// Crypto-block strings. The USDT path exists FOR the no-PayPal regions (China
// above all: ~1/3 of traffic, ~2% of buyers), so it must read natively there -
// zh/ja localized here, everything else falls back to English. On zh the
// <details> also renders OPEN and links a step-by-step tutorial page.
const CRYPTO_TEXT: Record<string, {
  eyebrow: string; hint: string; sub: string; chain: string; copy: string;
  how1: string; how2: string; how3: string; tutorial?: string;
  btcChain: string; btcNote: string;
}> = {
  en: {
    eyebrow: 'Pay with crypto',
    hint: "for regions where cards or PayPal aren't supported",
    sub: 'Paid in USDT on the TRON (TRC-20) network.',
    chain: 'Send to this TRON (TRC-20) address',
    copy: 'Copy',
    how1: 'Then email your ',
    how2: ' and the email for your pass to ',
    how3: ' Your signed pass comes back by email.',
    btcChain: 'Or pay in Bitcoin (on-chain) to this address',
    btcNote: 'Send the EUR amount in BTC at the current rate. One confirmation (~10-60 min); the network fee is yours. Then email the TXID as above.',
  },
  zh: {
    eyebrow: '使用 USDT 付款',
    hint: '无法使用 PayPal 或信用卡？推荐中国大陆用户使用此方式',
    sub: '通过 TRON（TRC-20）网络支付 USDT，价格如下（促销期间已按促销价换算）。',
    chain: '转账到这个 TRON（TRC-20）收款地址',
    copy: '复制',
    how1: '转账后，把',
    how2: '和接收 Pass 的邮箱发送至 ',
    how3: ' 签名后的 Pass 会通过邮件发回，导入 FunGen 即可解锁。',
    tutorial: '第一次用 USDT 购买？查看图文教程',
    btcChain: '或将比特币（链上）转账到这个地址',
    btcNote: '按当前汇率发送等值于欧元价格的 BTC。需要 1 个确认（约 10-60 分钟），矿工费自理。然后同样把 TXID 发邮件给我们。',
  },
  ja: {
    eyebrow: '暗号資産（USDT）で支払う',
    hint: 'カードやPayPalが使えない地域向けのお支払い方法',
    sub: 'TRON（TRC-20）ネットワークのUSDTでお支払いください。',
    chain: 'このTRON（TRC-20）アドレスに送金',
    copy: 'コピー',
    how1: '送金後、',
    how2: 'とPassを受け取るメールアドレスを次の宛先へ: ',
    how3: ' 署名済みのPassをメールでお送りします。',
    btcChain: 'またはビットコイン（オンチェーン）をこのアドレスへ',
    btcNote: '現在のレートでユーロ価格相当のBTCを送金してください。1承認（約10〜60分）が必要で、ネットワーク手数料はご負担ください。その後、同様にTXIDをメールでお送りください。',
  },
};
const cx = CRYPTO_TEXT[lang] ?? CRYPTO_TEXT.en;
const txidLabel = lang === 'zh' ? '交易 ID（TXID）' : lang === 'ja' ? 'トランザクションID（TXID）' : 'transaction ID';

// Visible sale deadline under the pricing header ("nothing said until when").
// The label comes from pricing.json; only the "until <date>" part localizes.
const promoUntil = (() => {
  if (!PROMO_ACTIVE || !PROMO_ENDS) return null;
  const [, m, d] = PROMO_ENDS.split('-').map((x) => parseInt(x, 10));
  const EN_MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  const until: Record<string, string> = {
    en: `until ${EN_MONTHS[m - 1]} ${d}`,
    de: `bis ${d}.${m}.`,
    es: `hasta el ${d}/${m}`,
    fr: `jusqu'au ${d}/${m}`,
    it: `fino al ${d}/${m}`,
    ja: `${m}月${d}日まで`,
    ko: `${m}월 ${d}일까지`,
    pt: `até ${d}/${m}`,
    ru: `до ${d}.${String(m).padStart(2, '0')}`,
    zh: `截止 ${m} 月 ${d} 日`,
  };
  return `${PROMO!.label} · ${until[lang] ?? until.en}`;
})();

// AI-section live demo: a real capture of the VR model tracking a scene
// (content pixelated for the storefront; logo, script timeline and the live
// position gauge untouched). Caption localized for the lever locales.
const AI_DEMO_TEXT: Record<string, { caption: string; alt: string }> = {
  en: {
    caption: 'Live VR tracking (video pixelated for the storefront).',
    alt: 'FunGen VR model live-tracking demo (pixelated): script timeline and device position gauge moving in real time',
  },
  zh: {
    caption: 'VR 实时追踪演示（画面已打码，应用内为完整视频）。',
    alt: 'FunGen VR 模型实时追踪演示（已打码）：脚本时间轴与设备位置实时联动',
  },
  ja: {
    caption: 'VRライブトラッキング（表示用にモザイク処理済み）。',
    alt: 'FunGen VRモデルのライブトラッキングデモ（モザイク処理済み）：スクリプトタイムラインとポジションゲージがリアルタイムに動作',
  },
};
const aiDemo = AI_DEMO_TEXT[lang] ?? AI_DEMO_TEXT.en;

// Alternating feature deep-dives: copy from the showcase dict, image filenames
// (in public/shots/) are structural. Optional inset floats over the main image.
// `vid` (when set) renders an autoplaying muted clip instead of `img`; w/h are
// the media's intrinsic size (reserve the box, no layout shift).
// Chapters/bookmarks + streamer rows removed 2026-07-02: power-user features
// that diluted the pitch (the dict entries remain for the in-app help/SEO).
const DIVES = [
  { d: sc.doctor, img: 'doctor', w: 1700, h: 1375 },
  { d: sc.transforms, img: 'library', w: 802, h: 1932 },
  { d: sc.palette, img: 'palette', vid: 'palette', w: 1144, h: 858 },
] as { d: typeof sc.doctor; img: string; w: number; h: number; vid?: string }[];
---

<!-- ░░ NAV ░░ -->
<header class="nav">
  <div class="wrap nav-inner">
    <a class="logo" href="#top">
      <img src={`${base}/icon-256.png`} alt="FunGen logo" width="32" height="32" />
      <span>FunGen</span>
    </a>
    <nav class="nav-links">
      <a href="#ai">{s.nav.ai}</a>
      <a href="#features">{s.nav.features}</a>
      <a href="#devices">{s.nav.devices}</a>
      <a href="#pricing">{s.nav.pricing}</a>
      <a href="#faq">{s.nav.faq}</a>
    </nav>
    <div class="nav-right">
      <LangSwitcher current={lang} />
      <a class="nav-cta" href={LINKS.releases} target="_blank" rel="noopener" data-umami-event="download-nav" data-os-cta data-os-tpl={s.hero.osCta}>{s.nav.download}</a>
    </div>
  </div>
</header>

<main id="top">
  <!-- ░░ HERO ░░ -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="lockup">
        <BrandMark size={190} />
        <div class="wordmark">FunGen</div>
      </div>
      <h1 class="hero-head">
        {headParts.map((part, i) => (i % 2 === 1 ? <span class="brand-text">{part}</span> : part))}
      </h1>
      <figure class="hero-video">
        <video width="2400" height="328" poster={`${base}/shots/fungenerate-poster.webp`} {...({ fetchpriority: 'high' } as Record<string, string>)} autoplay muted loop playsinline preload="metadata" aria-label={sc.gen.alt}>
          <source src={`${base}/shots/fungenerate.webm`} type="video/webm" />
          <source src={`${base}/shots/fungenerate.mp4`} type="video/mp4" />
        </video>
      </figure>
      <div class="hero-cta">
        <a class="btn btn-primary" href={LINKS.releases} target="_blank" rel="noopener" data-umami-event="download-hero" data-os-cta data-os-tpl={s.hero.osCta}>{s.hero.ctaDownload}</a>
      </div>
      <a class="hero-social" href={LINKS.discord} target="_blank" rel="noopener" data-umami-event="discord-hero">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.6 12.6 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.009c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.891.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.331c-1.182 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>{communityText}
      </a>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  <!-- ░░ AI MODELS ░░ -->
  <section id="ai" class="ai">
    <div class="wrap" data-reveal>
      <div class="section-head">
        <p class="eyebrow">{s.ai.eyebrow}</p>
        <h2>{s.ai.title}</h2>
        <p>{s.ai.body}</p>
      </div>
      <div class="grid models">
        {s.ai.models.map((m, i) => (
          <article class="card model-card">
            <div class="model-tag">{AI_TAGS[i]}</div>
            <h3>{m.title}</h3>
            <p>{m.body}</p>
          </article>
        ))}
      </div>
      <figure class="ai-demo">
        <video width="720" height="720" poster={`${base}/shots/live-vr-poster.webp`} autoplay muted loop playsinline preload="metadata" aria-label={aiDemo.alt}>
          <source src={`${base}/shots/live-vr.webm`} type="video/webm" />
          <source src={`${base}/shots/live-vr.mp4`} type="video/mp4" />
        </video>
        <figcaption>{aiDemo.caption}</figcaption>
      </figure>
    </div>
  </section>

  <!-- ░░ EDITOR HERO ░░ -->
  <section id="features" class="show-hero">
    <div class="wrap" data-reveal>
      <div class="section-head section-head--center">
        <p class="eyebrow">{sc.editor.eyebrow}</p>
        <h2>{sc.editor.title}</h2>
        <p>{sc.editor.body}</p>
      </div>
      <figure class="hero-shot">
        <img src={shot('editor-1')} width="2800" height="1488" loading="eager" decoding="async" fetchpriority="high" alt={sc.editor.alt} />
      </figure>
    </div>
  </section>

  <!-- ░░ FEATURE DEEP-DIVES ░░ -->
  {DIVES.map((row, i) => (
    <section class="show">
      <div class={`wrap show-row${i % 2 ? ' show-row--rev' : ''}`} data-reveal>
        <div class="show-media">
          {row.vid ? (
            <video class="show-frame" width={row.w} height={row.h} poster={`${base}/shots/${row.vid}-poster.webp`} autoplay muted loop playsinline preload="metadata" aria-label={row.d.alt}>
              <source src={`${base}/shots/${row.vid}.mp4`} type="video/mp4" />
            </video>
          ) : (
            <img class="show-frame" src={shot(row.img)} width={row.w} height={row.h} loading="lazy" decoding="async" alt={row.d.alt} />
          )}
        </div>
        <div class="show-text">
          <p class="eyebrow">{row.d.eyebrow}</p>
          <h2>{row.d.title}</h2>
          <p>{row.d.body}</p>
        </div>
      </div>
    </section>
  ))}

  <!-- ░░ DEVICES ░░ -->
  <section id="devices" class="devices">
    <div class="wrap devices-inner" data-reveal>
      <div>
        <div class="section-head" style="margin-bottom:24px">
          <p class="eyebrow">{s.devices.eyebrow}</p>
          <h2>{s.devices.title}</h2>
          <p>{s.devices.body}</p>
        </div>
        <ul class="device-list">
          {DEVICES.map((d) => <li>{d}</li>)}
        </ul>
        <a class="device-more" href={`${base}/supported-devices`}>How FunGen drives each device →</a>
      </div>
      <figure class="devices-shot">
        <img class="show-frame" src={shot('devices')} width="894" height="1316" loading="lazy" decoding="async" alt={sc.devicesAlt} />
      </figure>
    </div>
  </section>

  <!-- ░░ PRICING ░░ -->
  <section id="pricing">
    <div class="wrap" data-reveal>
      <div class="section-head">
        <p class="eyebrow">{s.pricing.eyebrow}</p>
        <h2>{s.pricing.title}</h2>
        {s.pricing.body.split('\n').map((line) => <p>{line}</p>)}
        {promoUntil && <p class="promo-until" data-promo-until>{promoUntil}</p>}
      </div>
      <div class="plans">
        {s.pricing.plans.map((plan, i) => {
          const meta = PLAN_META[i];
          const onPromo = !!meta.promoLabel;
          // Revert target if the promo lapses between static rebuilds: the list
          // price, its PayPal URL, and the umami event without the -promo suffix.
          const promoData = onPromo
            ? {
                'data-promo-ends': PROMO_ENDS,
                'data-list-price': meta.listPrice,
                'data-list-href': `${LINKS.paypal}/${meta.listAmount}`,
                'data-base-event': meta.event.replace(/-promo$/, ''),
              }
            : {};
          return (
            <article class={`plan${meta.featured ? ' plan-featured' : ''}${onPromo ? ' plan-promo' : ''}`} {...promoData}>
              {(plan.badge || onPromo) && (
                <div class="plan-badges">
                  {plan.badge && <span class="plan-badge">{plan.badge}</span>}
                  {onPromo && <span class="plan-badge plan-badge--promo" data-promo-badge>{meta.promoLabel}</span>}
                </div>
              )}
              <h3>{plan.name}</h3>
              <div class="plan-price">
                <span class="brand-text" data-price>{meta.price}</span>
                {onPromo && <s class="plan-list" data-promo-list>{meta.listPrice}</s>}
              </div>
              <p class="plan-cadence">{plan.cadence}</p>
              <p class="plan-blurb">{plan.blurb}</p>
              <ul>
                {plan.perks.map((perk) => <li>{perk}</li>)}
              </ul>
              <a class={`btn ${meta.featured ? 'btn-primary' : 'btn-ghost'} plan-cta`} data-cta href={meta.href} target="_blank" rel="noopener" data-umami-event={meta.event}>
                {plan.cta}
              </a>
            </article>
          );
        })}
      </div>
      {s.pricing.note.split('\n').map((line) => <p class="pricing-note">{line}</p>)}

      {CRYPTO.usdtAddress && (
        <details class="crypto-pay" id="crypto" data-reveal open={lang === 'zh'}>
          <summary class="crypto-summary">
            <span class="crypto-eyebrow">{cx.eyebrow}</span>
            <span class="crypto-summary-hint">{cx.hint}</span>
          </summary>
          <div class="crypto-body">
            <p class="crypto-sub">{cx.sub}</p>
            <div class="crypto-prices">
              {CRYPTO.prices.map((p) => (
                <div class="crypto-price">
                  <span class="crypto-price-tier">{p.label}</span>
                  <span class="crypto-price-amt">{p.usdt}<small>USDT</small></span>
                </div>
              ))}
            </div>
            <div class="crypto-addr">
              <span class="crypto-chain">{cx.chain}</span>
              <div class="crypto-copyrow">
                <code>{CRYPTO.usdtAddress}</code>
                <button type="button" class="crypto-copy" data-copy={CRYPTO.usdtAddress} data-umami-event="crypto-usdt">{cx.copy}</button>
              </div>
            </div>
            {CRYPTO.btcAddress && (
              <div class="crypto-addr">
                <span class="crypto-chain">{cx.btcChain}</span>
                <div class="crypto-copyrow">
                  <code>{CRYPTO.btcAddress}</code>
                  <button type="button" class="crypto-copy" data-copy={CRYPTO.btcAddress} data-umami-event="crypto-btc">{cx.copy}</button>
                </div>
                <p class="crypto-sub">{cx.btcNote}</p>
              </div>
            )}
            <p class="crypto-how">
              {cx.how1}<b>{txidLabel}</b>{cx.how2}
              <a href={`mailto:${CRYPTO.support}`}>{CRYPTO.support}</a>.{cx.how3}
            </p>
            {cx.tutorial && (
              <p class="crypto-how">
                <a href={`${base}/zh/how-to-buy-with-usdt`} data-umami-event="crypto-tutorial">{cx.tutorial} →</a>
              </p>
            )}
          </div>
        </details>
      )}
    </div>
  </section>

  <!-- ░░ FAQ ░░ -->
  <section id="faq" class="faq">
    <div class="wrap" data-reveal>
      <div class="section-head">
        <p class="eyebrow">{s.faq.eyebrow}</p>
        <h2>{s.faq.title}</h2>
      </div>
      <div class="faq-list">
        {s.faq.items.map((item) => (
          <details>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ FINAL CTA ░░ -->
  <section class="final-cta">
    <div class="wrap final-inner" data-reveal>
      <h2>{s.finalCta.title}</h2>
      <p>{s.finalCta.body}</p>
      <a class="btn btn-primary" href={LINKS.releases} target="_blank" rel="noopener" data-umami-event="download-final">{s.finalCta.cta}</a>
    </div>
  </section>
</main>

<!-- Sticky mobile-only download bar: appears once the hero scrolls off-screen. -->
<a class="btn btn-primary mobile-dl" href={LINKS.releases} target="_blank" rel="noopener" data-umami-event="download-sticky">{s.finalCta.cta}</a>

<!-- ░░ FOOTER ░░ -->
<footer class="footer">
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <img src={`${base}/icon-256.png`} alt="FunGen logo" width="28" height="28" />
      <div>
        <strong>FunGen</strong>
        <span>{s.footer.tagline}</span>
      </div>
    </div>
    <nav class="footer-links">
      <a href={LINKS.releases} target="_blank" rel="noopener" data-umami-event="download-footer">{s.footer.download}</a>
      <a href={LINKS.patreon} target="_blank" rel="noopener" data-umami-event="patreon">{s.footer.patreon}</a>
      <a href={LINKS.discord} target="_blank" rel="noopener" data-umami-event="discord">{s.footer.discord}</a>
      <a href={LINKS.contact}>{s.footer.contact}</a>
    </nav>
    <nav class="footer-links footer-guides" aria-label="Guides">
      <a href={`${base}/what-is-a-funscript`}>What is a funscript?</a>
      <a href={`${base}/generate-funscripts-from-video`}>Generate from video</a>
      <a href={`${base}/funscript-editor`}>Funscript editor</a>
      <a href={`${base}/vr-funscripts`}>VR funscripts</a>
      <a href={`${base}/supported-devices`}>Supported devices</a>
      <a href={`${base}/funscripts-for-the-handy`}>The Handy</a>
      <a href={`${base}/funscripts-for-osr2-sr6`}>OSR2 / SR6</a>
      <a href={`${base}/changelog`}>Changelog</a>
    </nav>
    <p class="footer-fine">{s.footer.fine}</p>
  </div>
</footer>

<script>
  // ── OS-aware download CTA (progressive enhancement) ───────────────────────
  // The generic label is server-rendered; if we can confidently detect a desktop
  // OS we relabel every [data-os-cta] to "Download for <OS>" and reveal the
  // secondary "Also for …" line. Mobile/unknown falls back to the generic label.
  (function () {
    var ua = navigator.userAgent || '';
    var uaData = (navigator as any).userAgentData;
    var plat = (uaData && uaData.platform) || navigator.platform || '';
    var hay = plat + ' ' + ua;
    var os = null;
    if (/Android/i.test(ua)) os = null;
    else if (/Mac/i.test(hay) && !/iPhone|iPad|iPod/i.test(hay) && !(navigator.maxTouchPoints > 1)) os = 'macOS';
    else if (/Win/i.test(hay)) os = 'Windows';
    else if (/Linux|X11|CrOS/i.test(hay)) os = 'Linux';
    if (os) {
      document.querySelectorAll('[data-os-cta]').forEach(function (el) {
        var tpl = el.getAttribute('data-os-tpl');
        if (tpl) el.textContent = tpl.replace('{os}', os);
      });
      var others = ['Windows', 'macOS', 'Linux'].filter(function (o) { return o !== os; });
      document.querySelectorAll('[data-os-also]').forEach(function (el) {
        var tpl = el.getAttribute('data-os-tpl');
        if (tpl) { el.textContent = tpl.replace('{platforms}', others.join(' · ')); el.removeAttribute('hidden'); }
      });
    }
  })();

  // ── Promo expiry guard ────────────────────────────────────────────────────
  // A promo is server-rendered only while live, but a static build can outlast
  // the promo window. If today is past a card's data-promo-ends, revert it to
  // the list price/URL and strip the promo visuals so an expired sale never shows.
  // (Pair with a daily GitHub Actions cron rebuild so promos also auto-START.)
  (function () {
    var today = new Date().toISOString().slice(0, 10);
    document.querySelectorAll('.plan-promo[data-promo-ends]').forEach(function (card) {
      if (card.getAttribute('data-promo-ends') >= today) return;
      card.classList.remove('plan-promo');
      var badge = card.querySelector('[data-promo-badge]'); if (badge) badge.remove();
      document.querySelectorAll('[data-promo-until]').forEach(function (el) { el.remove(); });
      var strike = card.querySelector('[data-promo-list]'); if (strike) strike.remove();
      var price = card.querySelector('[data-price]');
      var listPrice = card.getAttribute('data-list-price');
      if (price && listPrice) price.textContent = listPrice;
      var cta = card.querySelector('[data-cta]');
      var listHref = card.getAttribute('data-list-href');
      var baseEvent = card.getAttribute('data-base-event');
      if (cta && listHref) cta.setAttribute('href', listHref);
      if (cta && baseEvent) cta.setAttribute('data-umami-event', baseEvent);
    });
  })();

  // ── Sticky mobile download bar ────────────────────────────────────────────
  // Reveal the fixed bar once the hero is fully scrolled past (CSS handles the
  // mobile-only display + the prefers-reduced-motion transition).
  (function () {
    var hero = document.querySelector('.hero');
    var bar = document.querySelector('.mobile-dl');
    if (!hero || !bar || !('IntersectionObserver' in window)) return;
    new IntersectionObserver(function (entries) {
      bar.classList.toggle('is-visible', !entries[0].isIntersecting);
    }, { threshold: 0 }).observe(hero);
  })();

  // One-click copy for the crypto address.
  document.querySelectorAll('.crypto-copy').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var addr = btn.getAttribute('data-copy');
      var done = function () {
        var prev = btn.textContent;
        btn.textContent = 'Copied';
        btn.classList.add('copied');
        setTimeout(function () { btn.textContent = prev; btn.classList.remove('copied'); }, 1500);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(addr).then(done).catch(function () {});
      } else {
        var t = document.createElement('textarea');
        t.value = addr; document.body.appendChild(t); t.select();
        try { document.execCommand('copy'); done(); } catch (e) {}
        document.body.removeChild(t);
      }
    });
  });
</script>

